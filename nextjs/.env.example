# ==========================================================================
# AFFERENT SIGNAL — Next.js Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to Git.
# ==========================================================================

# Supabase project URL — browser-safe (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase anon/publishable key — browser-safe, read-only without RLS bypass
# Found in: Supabase Dashboard → Project Settings → API → anon/public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.REPLACE_ME

# Service role key — SERVER ONLY, used only in /app/api route handlers
# NEVER prefix with NEXT_PUBLIC_ — that would expose it to the browser
# Found in: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.REPLACE_ME

# Google Gemini API key (used if you call Gemini directly from Next.js edge functions)
GEMINI_API_KEY=AIza_REPLACE_ME

# FastAPI backend URL (for server-side fetch to backend)
NEXT_PUBLIC_API_URL=http://localhost:8000
