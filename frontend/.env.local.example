# ── Supabase ──────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Dashboard auth (comma-separated keys) ─────────────────────
# These keys gate the login screen — NOT the Supabase service role key
NEXT_PUBLIC_DASHBOARD_KEYS=your-strong-dashboard-key

# ── GitHub Pages base path (only needed if not using custom domain) ─
# Set to your repo name e.g. /afferent-signal
NEXT_PUBLIC_BASE_PATH=
